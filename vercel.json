{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/recompute",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/telemetry",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scout",
      "schedule": "0 14 * * 1"
    }
  ]
}
