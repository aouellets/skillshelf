# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=your_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_key
SUPABASE_SERVICE_ROLE_KEY=your_service_key

# MCP OAuth — HMAC secret used to sign the access/refresh tokens issued to
# claude.ai's connector during the OAuth flow (app/api/oauth/*). Set this to a
# long random string in production. If unset, the code falls back to
# SUPABASE_SERVICE_ROLE_KEY; in production one of the two MUST be present or the
# OAuth endpoints will 500 and the connector cannot register.
MCP_OAUTH_SECRET=your_long_random_secret

# Anthropic — used by the ingestion safety classifier (optional for the catalog)
ANTHROPIC_API_KEY=your_key

# Vercel AI Gateway — read automatically by the `ai` SDK when set (optional)
AI_GATEWAY_API_KEY=your_key

# Supabase new-style secret key (optional alternative to SUPABASE_SERVICE_ROLE_KEY;
# current code paths use SUPABASE_SERVICE_ROLE_KEY above)
SUPABASE_SECRET_KEY=your_secret_key

# GitHub — used by the ingestion script (optional)
GITHUB_TOKEN=your_token

# Admin — comma-separated emails allowed to review the submission queue.
# Sign in with one of these accounts to access /admin/submissions.
ADMIN_EMAILS=you@example.com

# Cron — secret guarding /api/cron/recompute (the hot-score refresh job).
# Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=your_random_secret

# Public URLs — the live deployment. Update to a custom domain once attached.
NEXT_PUBLIC_MCP_URL=https://skillme.dev/api/mcp
NEXT_PUBLIC_SITE_URL=https://skillme.dev

# Connect page screenshots — set to "true" once the PNGs exist in
# public/screenshots/ (settings-avatar, settings-integrations, add-integration).
NEXT_PUBLIC_SHOW_SCREENSHOTS=false
